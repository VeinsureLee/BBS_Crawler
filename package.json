{
  "name": "bbs-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:tsc": "tsc -p tsconfig.json --noEmit",

    "login": "tsx scripts/auth/do-login.ts",
    "login:once": "tsx scripts/auth/login-once.ts",

    "init:sections": "tsx scripts/init/init-sections.ts",
    "init:boards": "tsx scripts/init/init-boards.ts",
    "init:threads": "tsx scripts/init/init-threads.ts",
    "init": "npm run init:sections && npm run init:boards && npm run init:threads",
    "init:export": "tsx scripts/init/export-structure.ts",
    "refresh:stats": "tsx scripts/init/refresh-board-stats.ts",

    "db:check": "tsx scripts/db/check-db.ts",

    "crawl:board": "tsx scripts/crawl/crawl-board.ts",
    "crawl:section": "tsx scripts/crawl/crawl-section.ts",
    "crawl:pinned": "tsx scripts/crawl/crawl-pinned.ts",
    "crawl:board-skip": "tsx scripts/crawl/crawl-board-with-skip.ts",
    "crawl:thread": "tsx scripts/crawl/crawl-thread.ts"
  },
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.1",
    "pino": "^9.4.0",
    "playwright": "^1.46.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
