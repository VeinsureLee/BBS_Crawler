{
  "name": "bbs-crawler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:tsc": "tsc -p tsconfig.json --noEmit",

    "login": "tsx scripts/auth/do-login.ts",
    "login:once": "tsx scripts/auth/login-once.ts",

    "init:sections": "tsx scripts/init/init-sections.ts",
    "init:boards": "tsx scripts/init/init-boards.ts",
    "init:pinned": "tsx scripts/init/init-pinned.ts",
    "init": "npm run init:sections && npm run init:boards && npm run init:pinned",

    "db:check": "tsx scripts/db/check-db.ts",
    "db:migrate:up": "tsx scripts/db/migrate.ts up",
    "db:migrate:down": "tsx scripts/db/migrate.ts down",
    "db:migrate:status": "tsx scripts/db/migrate.ts status",
    "db:delete-pinned": "tsx scripts/db/delete-pinned.ts",

    "crawl:board": "tsx scripts/crawl/crawl-board.ts",
    "crawl:section": "tsx scripts/crawl/crawl-section.ts",
    "crawl:pinned": "tsx scripts/crawl/crawl-pinned.ts",
    "crawl:board-skip": "tsx scripts/crawl/crawl-board-with-skip.ts",

    "debug:board": "tsx scripts/debug/debug-board.ts",
    "debug:failed-boards": "tsx scripts/debug/explore-failed-boards.ts",
    "debug:find-thread": "tsx scripts/debug/find-thread.ts",
    "debug:inspect": "tsx scripts/debug/inspect-forum.ts",

    "explore": "tsx scripts/util/explore.ts",
    "format:html": "tsx scripts/util/format-html.ts"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/js-yaml": "^4.0.9",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.1",
    "pino": "^9.4.0",
    "playwright": "^1.46.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
